rules_version = '2';

// Firestore Security Rules — arxiv-digest-weekly
// Cerberus-authored. Last reviewed: 2026-04-11
//
// Design principles:
//   1. NO public client-side access to any collection.
//      Signup now goes through the `subscribe` Cloud Function (HTTP POST),
//      which runs under a service account and bypasses these rules entirely.
//   2. All reads/writes are service-account-only (Cloud Functions).
//   3. Zero Firebase JS SDK writes — eliminates the entire client-side attack surface.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── /subscribers/{docId} ────────────────────────────────────────────
    // All access via service account (Cloud Functions) only.
    // No client-side reads or writes permitted.
    match /subscribers/{docId} {
      allow read, write: if false;
    }

    // ── /pending_digest/{weekIso} ────────────────────────────────────────
    // No public access at all — read/write only via service account (Cloud Functions)
    match /pending_digest/{weekIso} {
      allow read, write: if false;
    }

    // ── /sent_log/{docId} ───────────────────────────────────────────────
    // No public access — write-only via service account (Cloud Functions)
    match /sent_log/{docId} {
      allow read, write: if false;
    }

    // ── Default: deny everything else ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
